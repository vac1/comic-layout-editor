<Window x:Class="ComicLayoutEditor.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About ComicLayout Editor"
        Height="300" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="ComicLayout Editor" FontSize="20" FontWeight="Bold" />
            <TextBlock x:Name="VersionText" Foreground="Gray" Margin="0,2,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,14,0,0">
            <TextBlock TextWrapping="Wrap"
                       Text="Desktop editor for laying out comics: A4 pages, panels, images and balloons." />
            <TextBlock TextWrapping="Wrap" Margin="0,10,0,0" FontWeight="SemiBold"
                       Text="Runs 100% locally, with no internet connection or cloud services." />
            <TextBlock TextWrapping="Wrap" Margin="0,10,0,0" Foreground="Gray" FontSize="11"
                       Text="Built with .NET 8 / WPF. Uses CommunityToolkit.Mvvm and PDFsharp (local libraries)." />
        </StackPanel>

        <Button Grid.Row="2" Content="Close" Width="90" HorizontalAlignment="Right"
                IsDefault="True" IsCancel="True" Click="Close_Click" />
    </Grid>
</Window>
