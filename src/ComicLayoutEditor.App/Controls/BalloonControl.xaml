<UserControl x:Class="ComicLayoutEditor.App.Controls.BalloonControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:ComicLayoutEditor.App.Converters"
             mc:Ignorable="d"
             Width="{Binding Width}"
             Height="{Binding Height}"
             PreviewMouseLeftButtonDown="BalloonControl_PreviewMouseLeftButtonDown">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBooleanConverter x:Key="InverseBool" />

        <Style x:Key="HandleStyle" TargetType="Thumb">
            <Setter Property="Width" Value="9" />
            <Setter Property="Height" Value="9" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Rectangle Fill="White" Stroke="MediumPurple" StrokeThickness="1.5" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Silueta del bocadillo: cuerpo con el piquito fundido en un solo contorno,
             más los globos del pensamiento (figuras aparte, debajo del cuerpo).
             Van en un Canvas para no inflar el tamaño deseado del Grid: así el piquito
             puede sobresalir del rectángulo del bocadillo sin que WPF lo recorte. -->
        <Canvas IsHitTestVisible="False">
            <Path Data="{Binding ThoughtBubblesGeometry}" Fill="White" Stroke="Black" StrokeThickness="1.5" />
            <Path Data="{Binding OutlineGeometry}" Fill="White" Stroke="Black" StrokeThickness="1.5" />
        </Canvas>

        <!-- Texto con formato (editable inline). El documento se construye en código
             desde los fragmentos del bocadillo (RichTextIo). -->
        <RichTextBox x:Name="TextEditor"
                     IsReadOnly="{Binding IsEditing, Converter={StaticResource InverseBool}}"
                     IsHitTestVisible="{Binding IsEditing}"
                     Background="Transparent" BorderThickness="0"
                     VerticalContentAlignment="Center"
                     Padding="6"
                     VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden"
                     SelectionChanged="TextEditor_SelectionChanged"
                     PreviewKeyDown="TextBox_PreviewKeyDown"
                     LostKeyboardFocus="TextBox_LostKeyboardFocus" />

        <!-- Cuerpo transparente para mover/seleccionar (desactivado al editar) -->
        <Thumb x:Name="MoveThumb" Cursor="SizeAll"
               IsHitTestVisible="{Binding IsEditing, Converter={StaticResource InverseBool}}"
               DragStarted="MoveThumb_DragStarted"
               DragDelta="MoveThumb_DragDelta"
               DragCompleted="Thumb_DragCompleted">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Path Data="{Binding BodyGeometry}" Fill="Transparent" />
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>

        <!-- Contorno de selección + tiradores -->
        <Grid Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}">
            <Rectangle Stroke="MediumPurple" StrokeThickness="1.5" StrokeDashArray="3 2"
                       IsHitTestVisible="False" />
            <Thumb Style="{StaticResource HandleStyle}" Tag="NW" Cursor="SizeNWSE"
                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-4.5,-4.5,0,0"
                   DragStarted="ResizeThumb_DragStarted" DragDelta="ResizeThumb_DragDelta" DragCompleted="Thumb_DragCompleted" />
            <Thumb Style="{StaticResource HandleStyle}" Tag="NE" Cursor="SizeNESW"
                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4.5,-4.5,0"
                   DragStarted="ResizeThumb_DragStarted" DragDelta="ResizeThumb_DragDelta" DragCompleted="Thumb_DragCompleted" />
            <Thumb Style="{StaticResource HandleStyle}" Tag="SW" Cursor="SizeNESW"
                   HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-4.5,0,0,-4.5"
                   DragStarted="ResizeThumb_DragStarted" DragDelta="ResizeThumb_DragDelta" DragCompleted="Thumb_DragCompleted" />
            <Thumb Style="{StaticResource HandleStyle}" Tag="SE" Cursor="SizeNWSE"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-4.5,-4.5"
                   DragStarted="ResizeThumb_DragStarted" DragDelta="ResizeThumb_DragDelta" DragCompleted="Thumb_DragCompleted" />
        </Grid>

        <!-- Tirador del piquito (fuera del Grid clip para poder salir del cuerpo) -->
        <Canvas Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}"
                IsHitTestVisible="True">
            <Thumb x:Name="TailThumb" Width="12" Height="12"
                   Canvas.Left="{Binding TailHandleX}" Canvas.Top="{Binding TailHandleY}"
                   Cursor="Cross"
                   DragStarted="TailThumb_DragStarted"
                   DragDelta="TailThumb_DragDelta"
                   DragCompleted="Thumb_DragCompleted">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse Fill="MediumPurple" Stroke="White" StrokeThickness="1.5" />
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
        </Canvas>

        <!-- Barra de formato de texto (solo al editar). En un Canvas para poder salir
             de la caja del bocadillo y colocarse encima. -->
        <Canvas Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <Border Canvas.Top="-40" Canvas.Left="0" Background="White"
                    BorderBrush="#B0B0B0" BorderThickness="1" CornerRadius="3" Padding="3"
                    SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.3" />
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <ToggleButton x:Name="BoldBtn" Content="B" FontWeight="Bold" Width="24" Focusable="False"
                                  Command="EditingCommands.ToggleBold" CommandTarget="{Binding ElementName=TextEditor}"
                                  ToolTip="Bold (Ctrl+B)" />
                    <ToggleButton x:Name="ItalicBtn" Content="I" FontStyle="Italic" Width="24" Focusable="False" Margin="2,0,0,0"
                                  Command="EditingCommands.ToggleItalic" CommandTarget="{Binding ElementName=TextEditor}"
                                  ToolTip="Italic (Ctrl+I)" />
                    <ToggleButton x:Name="UnderlineBtn" Width="24" Focusable="False" Margin="2,0,0,0"
                                  Command="EditingCommands.ToggleUnderline" CommandTarget="{Binding ElementName=TextEditor}"
                                  ToolTip="Underline (Ctrl+U)">
                        <TextBlock Text="U" TextDecorations="Underline" />
                    </ToggleButton>
                    <ComboBox x:Name="FontCombo" Width="120" Margin="6,0,0,0" MaxDropDownHeight="300"
                              ItemsSource="{Binding DataContext.AvailableFonts, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectionChanged="FontCombo_SelectionChanged" ToolTip="Fragment font" />
                    <ComboBox x:Name="SizeCombo" Width="52" Margin="4,0,0,0"
                              SelectionChanged="SizeCombo_SelectionChanged" ToolTip="Fragment size" />
                    <ComboBox x:Name="ColorCombo" Width="46" Margin="4,0,0,0"
                              SelectionChanged="ColorCombo_SelectionChanged" ToolTip="Fragment color">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Rectangle Width="26" Height="12" Fill="{Binding}" Stroke="#888888" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</UserControl>
