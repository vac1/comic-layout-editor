<UserControl x:Class="ComicLayoutEditor.App.Controls.PanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ComicLayoutEditor.App.Controls"
             mc:Ignorable="d"
             Width="{Binding Width}"
             Height="{Binding Height}"
             AllowDrop="True"
             DragOver="PanelControl_DragOver"
             Drop="PanelControl_Drop"
             PreviewMouseWheel="PanelControl_PreviewMouseWheel">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Estilo de los tiradores de redimensionado -->
        <Style x:Key="HandleStyle" TargetType="Thumb">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Rectangle Fill="White" Stroke="DodgerBlue" StrokeThickness="1.5" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Relleno de marcador de posición (viñeta sin imagen) -->
        <Border Background="#14000000"
                Visibility="{Binding PlaceholderVisible, Converter={StaticResource BoolToVis}}"
                IsHitTestVisible="False" />

        <!-- Imagen recortada al marco de la viñeta -->
        <Grid ClipToBounds="True" IsHitTestVisible="False">
            <Image Source="{Binding ImageSource}"
                   Stretch="{Binding ImageStretch}"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="{Binding ImageRenderZoom}" ScaleY="{Binding ImageRenderZoom}" />
                        <TranslateTransform X="{Binding ImageTranslateX}" Y="{Binding ImageTranslateY}" />
                    </TransformGroup>
                </Image.RenderTransform>
            </Image>
        </Grid>

        <!-- Borde siempre visible del marco -->
        <Rectangle Stroke="#88000000" StrokeThickness="1" IsHitTestVisible="False" />

        <!-- Cuerpo transparente = tirador de movimiento / selección -->
        <Thumb x:Name="MoveThumb" Cursor="SizeAll"
               DragStarted="MoveThumb_DragStarted"
               DragDelta="MoveThumb_DragDelta"
               DragCompleted="Thumb_DragCompleted"
               PreviewMouseLeftButtonDown="MoveThumb_PreviewMouseLeftButtonDown">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>

        <!-- Bocadillos (encima del cuerpo del panel para captar sus propios clics) -->
        <ItemsControl ItemsSource="{Binding Balloons}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding Left}" />
                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <controls:BalloonControl />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Contorno de selección -->
        <Rectangle Stroke="DodgerBlue" StrokeThickness="1.5" StrokeDashArray="3 2"
                   IsHitTestVisible="False"
                   Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}" />

        <!-- Tiradores de redimensionado (solo visibles con la viñeta seleccionada) -->
        <Grid Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}">
            <Thumb Style="{StaticResource HandleStyle}" Tag="NW" Cursor="SizeNWSE"
                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-5,-5,0,0"
                   DragStarted="ResizeThumb_DragStarted" DragDelta="ResizeThumb_DragDelta" DragCompleted="Thumb_DragCompleted" />
            <Thumb Style="{StaticResource HandleStyle}" Tag="N" Cursor="SizeNS"
                   HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-5,0,0"
                   DragStarted="ResizeThumb_DragStarted" DragDelta="ResizeThumb_DragDelta" DragCompleted="Thumb_DragCompleted" />
            <Thumb Style="{StaticResource HandleStyle}" Tag="NE" Cursor="SizeNESW"
                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-5,-5,0"
                   DragStarted="ResizeThumb_DragStarted" DragDelta="ResizeThumb_DragDelta" DragCompleted="Thumb_DragCompleted" />
            <Thumb Style="{StaticResource HandleStyle}" Tag="W" Cursor="SizeWE"
                   HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-5,0,0,0"
                   DragStarted="ResizeThumb_DragStarted" DragDelta="ResizeThumb_DragDelta" DragCompleted="Thumb_DragCompleted" />
            <Thumb Style="{StaticResource HandleStyle}" Tag="E" Cursor="SizeWE"
                   HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-5,0"
                   DragStarted="ResizeThumb_DragStarted" DragDelta="ResizeThumb_DragDelta" DragCompleted="Thumb_DragCompleted" />
            <Thumb Style="{StaticResource HandleStyle}" Tag="SW" Cursor="SizeNESW"
                   HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-5,0,0,-5"
                   DragStarted="ResizeThumb_DragStarted" DragDelta="ResizeThumb_DragDelta" DragCompleted="Thumb_DragCompleted" />
            <Thumb Style="{StaticResource HandleStyle}" Tag="S" Cursor="SizeNS"
                   HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-5"
                   DragStarted="ResizeThumb_DragStarted" DragDelta="ResizeThumb_DragDelta" DragCompleted="Thumb_DragCompleted" />
            <Thumb Style="{StaticResource HandleStyle}" Tag="SE" Cursor="SizeNWSE"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-5,-5"
                   DragStarted="ResizeThumb_DragStarted" DragDelta="ResizeThumb_DragDelta" DragCompleted="Thumb_DragCompleted" />
        </Grid>
    </Grid>
</UserControl>
