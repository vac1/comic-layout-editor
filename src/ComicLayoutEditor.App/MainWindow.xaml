<Window x:Class="ComicLayoutEditor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ComicLayoutEditor.App"
        xmlns:vm="clr-namespace:ComicLayoutEditor.App.ViewModels"
        xmlns:controls="clr-namespace:ComicLayoutEditor.App.Controls"
        xmlns:conv="clr-namespace:ComicLayoutEditor.App.Converters"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="720" Width="1180"
        WindowStartupLocation="CenterScreen"
        Icon="app.ico"
        Closing="Window_Closing">
    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>
    <Window.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:AddOneConverter x:Key="AddOne" />
        <conv:PixelsToMillimetersConverter x:Key="PxToMm" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewDocumentCommand}" />
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenDocumentCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveDocumentCommand}" />
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="{Binding SaveDocumentAsCommand}" />
        <KeyBinding Key="P" Modifiers="Control" Command="{Binding PrintDocumentCommand}" />
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}" />
        <KeyBinding Key="Escape" Command="{Binding ExitAdjustImageModeCommand}" />
        <KeyBinding Key="C" Modifiers="Control" Command="{Binding CopyCommand}" />
        <KeyBinding Key="X" Modifiers="Control" Command="{Binding CutCommand}" />
        <KeyBinding Key="V" Modifiers="Control" Command="{Binding PasteCommand}" />
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoActionCommand}" />
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding RedoActionCommand}" />
        <KeyBinding Key="Z" Modifiers="Control+Shift" Command="{Binding RedoActionCommand}" />
        <KeyBinding Key="Left" Command="{Binding NudgeCommand}" CommandParameter="Left" />
        <KeyBinding Key="Right" Command="{Binding NudgeCommand}" CommandParameter="Right" />
        <KeyBinding Key="Up" Command="{Binding NudgeCommand}" CommandParameter="Up" />
        <KeyBinding Key="Down" Command="{Binding NudgeCommand}" CommandParameter="Down" />
        <KeyBinding Key="D0" Modifiers="Control" Command="{Binding ResetZoomCommand}" />
        <KeyBinding Key="OemPlus" Modifiers="Control" Command="{Binding ZoomInCommand}" />
        <KeyBinding Key="Add" Modifiers="Control" Command="{Binding ZoomInCommand}" />
        <KeyBinding Key="OemMinus" Modifiers="Control" Command="{Binding ZoomOutCommand}" />
        <KeyBinding Key="Subtract" Modifiers="Control" Command="{Binding ZoomOutCommand}" />
    </Window.InputBindings>

    <DockPanel>
        <!-- Main menu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Command="{Binding NewDocumentCommand}" InputGestureText="Ctrl+N" />
                <MenuItem Header="_Open..." Command="{Binding OpenDocumentCommand}" InputGestureText="Ctrl+O" />
                <MenuItem Header="Open _Recent" ItemsSource="{Binding RecentFiles}"
                          IsEnabled="{Binding HasRecentFiles}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding FileName}" />
                            <Setter Property="ToolTip" Value="{Binding Path}" />
                            <Setter Property="Command"
                                    Value="{Binding DataContext.OpenRecentCommand,
                                            RelativeSource={RelativeSource AncestorType=Menu}}" />
                            <Setter Property="CommandParameter" Value="{Binding Path}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <MenuItem Header="_Clear Recent" Command="{Binding ClearRecentFilesCommand}"
                          IsEnabled="{Binding HasRecentFiles}" />
                <Separator />
                <MenuItem Header="_Save" Command="{Binding SaveDocumentCommand}" InputGestureText="Ctrl+S" />
                <MenuItem Header="Save _As..." Command="{Binding SaveDocumentAsCommand}" InputGestureText="Ctrl+Shift+S" />
                <Separator />
                <MenuItem Header="_Export to PDF..." Command="{Binding ExportPdfCommand}" />
                <MenuItem Header="Export as P_NG..." Command="{Binding ExportPngCommand}" />
                <Separator />
                <MenuItem Header="Print Pre_view..." Command="{Binding PrintPreviewCommand}" />
                <MenuItem Header="_Print..." Command="{Binding PrintDocumentCommand}" InputGestureText="Ctrl+P" />
                <Separator />
                <MenuItem Header="E_xit" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Command="{Binding UndoActionCommand}" InputGestureText="Ctrl+Z" />
                <MenuItem Header="_Redo" Command="{Binding RedoActionCommand}" InputGestureText="Ctrl+Y" />
                <Separator />
                <MenuItem Header="_Copy" Command="{Binding CopyCommand}" InputGestureText="Ctrl+C" />
                <MenuItem Header="Cu_t" Command="{Binding CutCommand}" InputGestureText="Ctrl+X" />
                <MenuItem Header="_Paste" Command="{Binding PasteCommand}" InputGestureText="Ctrl+V" />
                <Separator />
                <MenuItem Header="_Delete Selection" Command="{Binding DeleteSelectedCommand}" InputGestureText="Del" />
            </MenuItem>
            <MenuItem Header="_Page">
                <MenuItem Header="_Add Page" Command="{Binding AddPageCommand}" />
                <MenuItem Header="D_uplicate Page" Command="{Binding DuplicatePageCommand}" />
                <MenuItem Header="_Delete Page" Command="{Binding DeletePageCommand}" />
                <Separator />
                <MenuItem Header="Move _Up" Command="{Binding MovePageUpCommand}" />
                <MenuItem Header="Move _Down" Command="{Binding MovePageDownCommand}" />
                <Separator />
                <MenuItem Header="Toggle _Orientation" Command="{Binding ToggleOrientationCommand}" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Zoom _In" Command="{Binding ZoomInCommand}" InputGestureText="Ctrl++" />
                <MenuItem Header="Zoom _Out" Command="{Binding ZoomOutCommand}" InputGestureText="Ctrl+-" />
                <MenuItem Header="Zoom _100%" Command="{Binding ResetZoomCommand}" InputGestureText="Ctrl+0" />
                <MenuItem Header="_Fit to Window" Command="{Binding FitToWindowCommand}" />
                <Separator />
                <MenuItem Header="Show _Grid" IsCheckable="True" IsChecked="{Binding ShowGrid}" />
                <MenuItem Header="Snap to _Grid" IsCheckable="True" IsChecked="{Binding SnapToGrid}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About..." Click="About_Click" />
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <ToggleButton Content="✏ New Panel"
                              IsChecked="{Binding IsCreatePanelMode}"
                              ToolTip="Create panel mode: drag on the page" />
                <Button Content="💬 New Balloon" Command="{Binding NewBalloonCommand}"
                        ToolTip="Add a balloon to the selected panel" />
                <Button Content="🏷 Caption" Command="{Binding NewCaptionCommand}"
                        ToolTip="Add a narration caption (rectangle without a tail)" />
                <Separator />
                <Button Content="↶ Undo" Command="{Binding UndoActionCommand}" ToolTip="Undo (Ctrl+Z)" />
                <Button Content="↷ Redo" Command="{Binding RedoActionCommand}" ToolTip="Redo (Ctrl+Y)" />
                <Separator />
                <Button Content="🗑 Delete" Command="{Binding DeleteSelectedCommand}" ToolTip="Delete selection (Del)" />
                <Separator />
                <Button Content="⬆ Bring to Front" Command="{Binding BringToFrontCommand}" />
                <Button Content="⬇ Send to Back" Command="{Binding SendToBackCommand}" />
            </ToolBar>

            <ToolBar>
                <TextBlock Text="Align:" VerticalAlignment="Center" Margin="2,0" />
                <Button Content="Left" Command="{Binding AlignLeftCommand}" ToolTip="Align left" />
                <Button Content="Center H" Command="{Binding AlignCenterHorizontalCommand}" ToolTip="Center horizontally" />
                <Button Content="Right" Command="{Binding AlignRightCommand}" ToolTip="Align right" />
                <Button Content="Top" Command="{Binding AlignTopCommand}" ToolTip="Align top" />
                <Button Content="Middle V" Command="{Binding AlignMiddleVerticalCommand}" ToolTip="Center vertically" />
                <Button Content="Bottom" Command="{Binding AlignBottomCommand}" ToolTip="Align bottom" />
                <Separator />
                <Button Content="Distribute H" Command="{Binding DistributeHorizontalCommand}" />
                <Button Content="Distribute V" Command="{Binding DistributeVerticalCommand}" />
            </ToolBar>

            <ToolBar>
                <TextBlock Text="Image:" VerticalAlignment="Center" Margin="2,0" />
                <Button Content="🖼 Import" Command="{Binding ImportImageCommand}"
                        ToolTip="Import an image into the selected panel" />
                <Button Content="✖ Remove" Command="{Binding RemoveImageCommand}"
                        ToolTip="Remove the image from the panel" />
                <Button Content="⟲" Command="{Binding RotateImageCommand}" CommandParameter="Left"
                        ToolTip="Rotate the image 90° left" />
                <Button Content="⟳" Command="{Binding RotateImageCommand}" CommandParameter="Right"
                        ToolTip="Rotate the image 90° right" />
                <Separator />
                <ToggleButton Content="🔍 Adjust"
                              IsChecked="{Binding IsAdjustImageMode}"
                              IsEnabled="{Binding HasSingleSelection}"
                              ToolTip="Adjust image inside the frame: drag to pan, wheel or corner handles to zoom (Esc to exit). Also works with Alt+drag / Alt+wheel." />
                <Button Content="↺ Reset" Command="{Binding ResetImageTransformCommand}"
                        ToolTip="Reset the image framing (zoom 100%, centered)" />
                <TextBlock Text="Fit:" VerticalAlignment="Center" Margin="6,0,2,0" />
                <ComboBox Width="90" VerticalAlignment="Center"
                          ItemsSource="{Binding ImageFits}"
                          SelectedItem="{Binding SelectedImageFit}"
                          IsEnabled="{Binding HasSingleSelection}"
                          ToolTip="Cover / Contain / Stretch" />
            </ToolBar>

            <ToolBar>
                <CheckBox Content="Grid" IsChecked="{Binding ShowGrid}" VerticalAlignment="Center"
                          ToolTip="Show grid" />
                <CheckBox Content="Snap" IsChecked="{Binding SnapToGrid}" VerticalAlignment="Center"
                          Margin="4,0,0,0" ToolTip="Snap to grid when moving/resizing" />
                <ComboBox Width="60" VerticalAlignment="Center" Margin="4,0,0,0"
                          ItemsSource="{Binding GridSizeOptions}"
                          SelectedItem="{Binding GridSizeMm}"
                          ToolTip="Grid size in mm">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StringFormat={}{0} mm}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </ToolBar>

            <ToolBar>
                <Button Content="➖" Command="{Binding ZoomOutCommand}" ToolTip="Zoom out (Ctrl+-)" />
                <TextBlock Text="{Binding Zoom, StringFormat={}{0:P0}}" VerticalAlignment="Center"
                           Width="42" TextAlignment="Center" />
                <Button Content="➕" Command="{Binding ZoomInCommand}" ToolTip="Zoom in (Ctrl++)" />
                <Slider Width="110" Minimum="0.25" Maximum="4" Value="{Binding Zoom}"
                        VerticalAlignment="Center" TickFrequency="0.25" />
                <Button Content="⊡ Fit" Command="{Binding FitToWindowCommand}" ToolTip="Fit to window" />
            </ToolBar>
        </ToolBarTray>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock>
                    <Run Text="Page" />
                    <Run Text="{Binding CurrentPageIndex, Converter={StaticResource AddOne}, Mode=OneWay}" />
                    <Run Text="of" />
                    <Run Text="{Binding PageCount, Mode=OneWay}" />
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding SelectedPanels.Count, StringFormat=Panels selected: {0}}" />
            </StatusBarItem>
        </StatusBar>

        <!-- Page thumbnails panel -->
        <Border DockPanel.Dock="Left" Width="170" Background="#ECECEC"
                BorderBrush="#C0C0C0" BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Pages" FontWeight="Bold"
                           Margin="8,6" />
                <ToolBarTray DockPanel.Dock="Top" IsLocked="True" Background="Transparent">
                    <ToolBar Background="Transparent">
                        <Button Content="➕" Command="{Binding AddPageCommand}" ToolTip="Add page" />
                        <Button Content="⧉" Command="{Binding DuplicatePageCommand}" ToolTip="Duplicate page" />
                        <Button Content="🗑" Command="{Binding DeletePageCommand}" ToolTip="Delete page" />
                        <Separator />
                        <Button Content="▲" Command="{Binding MovePageUpCommand}" ToolTip="Move up" />
                        <Button Content="▼" Command="{Binding MovePageDownCommand}" ToolTip="Move down" />
                    </ToolBar>
                </ToolBarTray>

                <ListBox ItemsSource="{Binding Pages}"
                         SelectedItem="{Binding CurrentPage}"
                         AlternationCount="9999"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4">
                                <TextBlock HorizontalAlignment="Center" Margin="0,0,0,2" FontSize="11">
                                    <Run Text="Page" />
                                    <Run Text="{Binding (ItemsControl.AlternationIndex),
                                               RelativeSource={RelativeSource AncestorType=ListBoxItem},
                                               Converter={StaticResource AddOne}, Mode=OneWay}" />
                                </TextBlock>
                                <Border Background="White" BorderBrush="#999" BorderThickness="1"
                                        HorizontalAlignment="Center">
                                    <Viewbox Width="120" Stretch="Uniform">
                                        <Grid Width="{Binding PageWidthPx}" Height="{Binding PageHeightPx}"
                                              Background="White" ClipToBounds="True">
                                            <ItemsControl ItemsSource="{Binding Panels}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas ClipToBounds="True" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style TargetType="ContentPresenter">
                                                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                                        <Setter Property="Canvas.Top" Value="{Binding Top}" />
                                                        <Setter Property="Width" Value="{Binding Width}" />
                                                        <Setter Property="Height" Value="{Binding Height}" />
                                                        <Setter Property="Panel.ZIndex" Value="{Binding ZIndex}" />
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid ClipToBounds="True">
                                                            <Rectangle Fill="#DDDDDD" Stroke="#888" StrokeThickness="2" />
                                                            <Image Source="{Binding ImageSource}" Stretch="UniformToFill" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Viewbox>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Contextual properties panel -->
        <Border DockPanel.Dock="Right" Width="240" Background="#F0F0F0"
                BorderBrush="#C0C0C0" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <!-- Balloon properties -->
                    <StackPanel Margin="10" DataContext="{Binding SelectedBalloon}"
                                Visibility="{Binding DataContext.SelectedBalloon,
                                             RelativeSource={RelativeSource AncestorType=Window},
                                             Converter={StaticResource NullToVis}}">
                        <TextBlock Text="Balloon" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" />

                        <TextBlock Text="Shape" Margin="0,4,0,2" />
                        <ComboBox ItemsSource="{Binding DataContext.BalloonShapes, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding Shape}" />

                        <TextBlock Text="Font" Margin="0,8,0,2" />
                        <ComboBox ItemsSource="{Binding DataContext.AvailableFonts, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding FontFamily}" IsEditable="False" MaxDropDownHeight="300" />

                        <TextBlock Text="Size" Margin="0,8,0,2" />
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right" Width="34"
                                       Text="{Binding FontSize, StringFormat={}{0:0}}" TextAlignment="Right" />
                            <Slider Minimum="8" Maximum="72" Value="{Binding FontSize}" />
                        </DockPanel>

                        <TextBlock Text="Alignment" Margin="0,8,0,2" />
                        <ComboBox ItemsSource="{Binding DataContext.TextAligns, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding TextAlign}" />

                        <TextBlock Text="Text" Margin="0,8,0,2" />
                        <TextBlock Foreground="Gray" FontSize="11" TextWrapping="Wrap"
                                   Text="Double-click the balloon to edit its text. While editing, a toolbar appears with bold, italic, underline, font, size and per-fragment color. The font/size/alignment here are the balloon's default values." />

                        <CheckBox Content="Show tail" Margin="0,12,0,0"
                                  IsChecked="{Binding HasTail}"
                                  IsEnabled="{Binding SupportsTail}" />
                        <TextBlock Text="Drag it from the purple circle."
                                   TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,4,0,0"
                                   Visibility="{Binding HasTail, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>

                    <!-- Panel properties -->
                    <StackPanel Margin="10"
                                Visibility="{Binding HasPanelSelection, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Panel" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding SelectedPanels.Count, StringFormat=Selected: {0}}"
                                   Foreground="Gray" Margin="0,0,0,6" />

                        <StackPanel DataContext="{Binding PrimaryPanel}"
                                    Visibility="{Binding DataContext.HasSingleSelection,
                                                 RelativeSource={RelativeSource AncestorType=Window},
                                                 Converter={StaticResource BoolToVis}}">
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,2">
                                    <Run Text="X:" Foreground="Gray" />
                                    <Run Text="{Binding Left, Converter={StaticResource PxToMm}, Mode=OneWay}" />
                                    <Run Text="mm" Foreground="Gray" />
                                </TextBlock>
                                <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,2">
                                    <Run Text="Y:" Foreground="Gray" />
                                    <Run Text="{Binding Top, Converter={StaticResource PxToMm}, Mode=OneWay}" />
                                    <Run Text="mm" Foreground="Gray" />
                                </TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,2">
                                    <Run Text="W:" Foreground="Gray" />
                                    <Run Text="{Binding Width, Converter={StaticResource PxToMm}, Mode=OneWay}" />
                                    <Run Text="mm" Foreground="Gray" />
                                </TextBlock>
                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,2">
                                    <Run Text="H:" Foreground="Gray" />
                                    <Run Text="{Binding Height, Converter={StaticResource PxToMm}, Mode=OneWay}" />
                                    <Run Text="mm" Foreground="Gray" />
                                </TextBlock>
                            </Grid>
                        </StackPanel>

                        <TextBlock Text="Image" Margin="0,8,0,2" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Import" Command="{Binding ImportImageCommand}" Margin="0,0,4,0" />
                            <Button Content="Remove" Command="{Binding RemoveImageCommand}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <ToggleButton Content="Adjust" IsChecked="{Binding IsAdjustImageMode}"
                                          IsEnabled="{Binding HasSingleSelection}" Margin="0,0,4,0"
                                          ToolTip="Adjust image inside the frame: drag to pan, wheel or corner handles to zoom (Esc to exit)" />
                            <Button Content="Reset frame" Command="{Binding ResetImageTransformCommand}"
                                    ToolTip="Reset the image framing (zoom 100%, centered)" />
                        </StackPanel>
                        <TextBlock Text="Fit" Margin="0,8,0,2" />
                        <ComboBox ItemsSource="{Binding ImageFits}" SelectedItem="{Binding SelectedImageFit}"
                                  IsEnabled="{Binding HasSingleSelection}" />

                        <TextBlock Text="Order" Margin="0,8,0,2" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Front" Command="{Binding BringToFrontCommand}" Margin="0,0,4,0" />
                            <Button Content="Back" Command="{Binding SendToBackCommand}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Document / page properties -->
                    <StackPanel Margin="10"
                                Visibility="{Binding IsNothingSelected, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Document" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" />
                        <TextBlock Text="Title" Margin="0,4,0,2" />
                        <TextBox Text="{Binding DocumentTitle, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Page" FontWeight="Bold" FontSize="14" Margin="0,16,0,8" />
                        <TextBlock>
                            <Run Text="Page" />
                            <Run Text="{Binding CurrentPageIndex, Converter={StaticResource AddOne}, Mode=OneWay}" />
                            <Run Text="of" />
                            <Run Text="{Binding PageCount, Mode=OneWay}" />
                        </TextBlock>

                        <TextBlock Text="Size (mm)" Margin="0,8,0,2" />
                        <TextBlock Foreground="Gray">
                            <Run Text="{Binding CurrentPage.SizeMm.Width, StringFormat={}{0:0}, Mode=OneWay}" />
                            <Run Text="×" />
                            <Run Text="{Binding CurrentPage.SizeMm.Height, StringFormat={}{0:0}, Mode=OneWay}" />
                        </TextBlock>

                        <Button Content="Toggle orientation" Command="{Binding ToggleOrientationCommand}"
                                Margin="0,10,0,0" HorizontalAlignment="Left" />

                        <TextBlock Text="Select a panel or a balloon to see its properties."
                                   TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,16,0,0" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- Canvas -->
        <controls:PageCanvasControl />
    </DockPanel>
</Window>
